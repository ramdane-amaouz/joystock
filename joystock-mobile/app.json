{
  "expo": {
    "name": "joystock-mobile",
    "slug": "joystock-mobile",
    "scheme": "joystock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/head-img.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/head-img.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/head-img.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.moumouh69.joystockmobile"
    },
    "web": {
      "favicon": "./assets/head-img.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0b83a18f-cdce-4859-a4a9-7eee150644ec"
      }
    }
  }
}
